# Copy this file to .env and fill in your real values.
# .env is in .gitignore — it will never be committed.

ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
MISTRAL_API_KEY=Clave...

# Optional: change the port the server listens on (default 3000)
# PORT=3000

# Behind a reverse proxy (Railway, Render, nginx…): number of proxy hops to trust
# so req.ip / rate limiting use the real client IP. Leave unset for direct exposure.
# TRUST_PROXY=1

# Optional: production safety limits
# MAX_TOKENS=4096
# MAX_MESSAGES=24
# MAX_MESSAGE_CHARS=4000
# MAX_REPORT_CONTENT_CHARS=6000
# MAX_REPORT_COMMENT_CHARS=800
# MAX_STORED_REPORTS=200
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=20
