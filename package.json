{
  "name": "theos",
  "version": "1.0.2",
  "description": "Catholic theologian chatbot — Anthropic API proxy",
  "author": {
    "name": "Alejandro Viveros Dominguez",
    "email": "alex@viveros.click"
  },
  "type": "module",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage",
    "electron": "electron --no-sandbox .",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.22.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.theos.app",
    "productName": "Theos",
    "files": [
      "electron-main.js",
      "server.js",
      "system-prompt.js",
      "public/**/*",
      "node_modules/**/*"
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Education",
      "icon": "build/icons",
      "executableName": "theos",
      "syncDesktopName": true
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
